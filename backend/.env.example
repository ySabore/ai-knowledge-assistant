# Copy to backend/.env or project-root .env (UTF-8). Loaded on API/worker startup.

# --- Registry (optional override) ---
# REGISTRY_DATABASE_PATH=/absolute/path/to/app.db

# --- CORS ---
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Dev auth ---
# DEV_BEARER_TOKEN=dev-local-token
# DEV_USER_ID=user-alpha

# --- Auth mode ---
# dev   = local bearer token flow
# clerk = verify Clerk JWT against JWKS
AUTH_MODE=dev
# Set for Clerk mode (example):
# CLERK_DOMAIN=your-instance.clerk.accounts.dev
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_AUDIENCE=

# --- Pinecone (required for RAG + ingestion) ---
# Create an index whose vector dimension matches your embedding model (see PINECONE_EMBEDDING_DIMENSION).
PINECONE_API_KEY=
# Serverless / dedicated: use the full host URL from the Pinecone console (preferred).
PINECONE_INDEX_HOST=
# Or legacy: index name only (when not using host).
# PINECONE_INDEX_NAME=ai-knowledge-assistant

# text-embedding-3-small => 1536 (default). Ollama nomic-embed-text => 768.
PINECONE_EMBEDDING_DIMENSION=768

# --- Embeddings ---
# Production profile: openai
# EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local profile: ollama (matches dimension 768)
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Chat: production default openai ---
LLM_PROVIDER=openai
OPENAI_CHAT_MODEL=gpt-4o-mini

# Anthropic option for production
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022

# Local LLM option
# LLM_PROVIDER=ollama
OLLAMA_CHAT_MODEL=llama3.2

# --- RAG tuning ---
# RAG_RETRIEVAL_LIMIT=8
# RAG_CHUNK_SIZE=1200
# RAG_CHUNK_OVERLAP=150
# RAG_TEMPERATURE=0.2
# RAG_METADATA_TEXT_MAX_CHARS=12000

# --- Ingestion worker: allowed file roots (comma-separated). Default: <project>/demos ---
# INGEST_ALLOWED_PATHS=/abs/path/to/demos
# INGEST_POLL_INTERVAL_SECONDS=5
